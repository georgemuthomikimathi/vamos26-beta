{
  "name": "vamos26-beta",
  "version": "0.1.0-beta",
  "private": true,
  "scripts": {
    "copy-flags": "mkdir -p public/flags/1x1 && for code in mx za kr cz ca ba qa ch br ma ht gb-sct us py au tr de cw ci ec nl jp se tn be eg ir nz es cv sa uy fr sn iq no ar dz at jo pt cd uz co gb-eng hr gh pa it pe; do cp node_modules/flag-icons/flags/1x1/$code.svg public/flags/1x1/$code.svg; done",
    "process-images": "python3 scripts/remove-image-bg.py",
    "fetch-portraits": "python3 scripts/fetch-player-portraits.py",
    "postinstall": "npm run copy-flags",
    "dev": "next dev --webpack -H 127.0.0.1 -p 3000",
    "dev:alt": "next dev --webpack -H 127.0.0.1 -p 3040",
    "start:prod": "next start -H 127.0.0.1 -p 3000",
    "build": "next build",
    "start": "next start",
    "lint": "eslint"
  },
  "dependencies": {
    "flag-icons": "^7.5.0",
    "framer-motion": "^12.40.0",
    "lucide-react": "^1.17.0",
    "next": "16.2.7",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.7",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
